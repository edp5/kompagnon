{
  "name": "api",
  "description": "The api of Kompagnon platform",
  "homepage": "https://github.com/edp5/kompagnon#readme",
  "bugs": {
    "url": "https://github.com/edp5/kompagnon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edp5/kompagnon.git"
  },
  "license": "MIT",
  "author": "edp5",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:prepare && cross-env NODE_ENV=test vitest run",
    "test:coverage": "npm run test:prepare && cross-env NODE_ENV=test vitest run --coverage",
    "test:ui": "npm run test:prepare && cross-env NODE_ENV=test vitest --ui",
    "test:prepare": "cross-env NODE_ENV=test npm run db:prepare",
    "dev": "nodemon index.js",
    "start": "node index.js",
    "db:new-migration": "knex --knexfile ./db/knexfile.js  migrate:make --stub $PWD/db/template.js $migrationname",
    "db:create": "node --env-file-if-exists=.env ./db/create-database.js",
    "db:delete": "node --env-file-if-exists=.env ./db/drop-database.js",
    "db:empty": "node --env-file-if-exists=.env ./db/empty-database.js",
    "db:migrate": "knex --knexfile ./db/knexfile.js  migrate:latest",
    "db:rollback:latest": "knex --knexfile ./db/knexfile.js  migrate:down",
    "db:prepare": "npm run db:delete && npm run db:create && npm run db:migrate",
    "db:seed": "knex --knexfile ./db/knexfile.js seed:run",
    "db:reset": "npm run db:prepare && npm run db:seed",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "swagger:jsdoc:templates": "node ./scripts/generate-swagger-jsdoc.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "celebrate": "^15.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.3.0",
    "lodash": "^4.18.1",
    "marked": "^18.0.5",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.0.4",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-jsdoc": "^63.0.11",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vitest-globals": "^1.6.1",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  },
  "version": "0.3.0"
}
